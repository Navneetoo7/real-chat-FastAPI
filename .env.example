# App
APP_NAME=real-time-ai-chat
ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Security — generate real secrets for production
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Postgres (matches docker-compose)
DATABASE_URL=postgresql+asyncpg://chat:chat@localhost:5432/chatdb

# Redis (matches docker-compose)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]